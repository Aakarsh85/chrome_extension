{
  "manifest_version": 3,

  "name": "Smart Bookmark Manager",

  "description": "Save webpages and organize them into custom groups with smart categorization.",

  "version": "1.0",

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Smart Bookmark"
  },

  "permissions": [
    "storage",
    "tabs"
  ],

  "host_permissions": [
    "http://localhost:3000/*"
  ],

  "background": {
    "service_worker": "background/background.js"
  },

  "commands": {
    "save-bookmark": {
      "suggested_key": {
        "default": "Ctrl+Shift+S"
      },
      "description": "Save current page as bookmark"
    }
  }
}